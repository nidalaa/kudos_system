<div data-controller="kudos-dashboard"
     data-kudos-dashboard-categories-value="<%= @categories.map { |c| { name: c.name, description: c.description } }.to_json %>"
     class="min-h-screen bg-gray-50">

  <!-- Header -->
  <header class="bg-white border-b border-gray-200 px-6 py-4">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
      <div>
        <h1 class="text-xl font-semibold text-gray-900">Kudos Review</h1>
        <p class="text-sm text-gray-500 mt-0.5">Review and approve AI-extracted kudos from Slack</p>
      </div>
    </div>
  </header>

  <!-- Main content -->
  <main class="max-w-7xl mx-auto px-6 py-6">

    <!-- Tab bar + actions -->
    <div class="flex items-center justify-between mb-4">
      <div class="flex gap-2">
        <button
          data-tab="pending"
          data-action="click->kudos-dashboard#switchTab"
          data-kudos-dashboard-target="tabButton"
          class="px-4 py-2 rounded-md text-sm font-medium transition-colors">
          Pending&nbsp;<span class="ml-1 bg-white bg-opacity-30 rounded px-1.5 py-0.5 text-xs font-semibold" data-kudos-dashboard-target="pendingCount"><%= @kudos.count { |k| k[:status] == "pending" } %></span>
        </button>
        <button
          data-tab="approved"
          data-action="click->kudos-dashboard#switchTab"
          data-kudos-dashboard-target="tabButton"
          class="px-4 py-2 rounded-md text-sm font-medium transition-colors">
          Approved&nbsp;<span class="ml-1 bg-white bg-opacity-30 rounded px-1.5 py-0.5 text-xs font-semibold" data-kudos-dashboard-target="approvedCount"><%= @kudos.count { |k| k[:status] == "approved" } %></span>
        </button>
        <button
          data-tab="rejected"
          data-action="click->kudos-dashboard#switchTab"
          data-kudos-dashboard-target="tabButton"
          class="px-4 py-2 rounded-md text-sm font-medium transition-colors">
          Rejected&nbsp;<span class="ml-1 bg-white bg-opacity-30 rounded px-1.5 py-0.5 text-xs font-semibold" data-kudos-dashboard-target="rejectedCount"><%= @kudos.count { |k| k[:status] == "rejected" } %></span>
        </button>
      </div>

      <div class="flex items-center gap-3">
        <input
          type="file"
          accept=".json"
          class="hidden"
          data-kudos-dashboard-target="fileInput"
          data-action="change->kudos-dashboard#handleFile">

        <button
          data-action="click->kudos-dashboard#triggerUpload"
          class="inline-flex items-center gap-2 px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-500" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM6.293 6.707a1 1 0 010-1.414l3-3a1 1 0 011.414 0l3 3a1 1 0 01-1.414 1.414L11 5.414V13a1 1 0 11-2 0V5.414L7.707 6.707a1 1 0 01-1.414 0z" clip-rule="evenodd" />
          </svg>
          Upload JSON
        </button>

        <input
          type="search"
          placeholder="Search kudos…"
          data-action="input->kudos-dashboard#search"
          class="w-56 px-3 py-2 text-sm border border-gray-300 rounded-md bg-white text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
      </div>
    </div>

    <!-- Bulk action bar (shown when rows are selected) -->
    <div data-kudos-dashboard-target="bulkBar" class="hidden mb-3 flex items-center gap-4 px-4 py-3 bg-indigo-50 border border-indigo-200 rounded-lg">
      <span class="text-sm font-medium text-indigo-800 whitespace-nowrap">
        <span data-kudos-dashboard-target="selectedCount">0</span> selected
      </span>

      <div class="h-4 w-px bg-indigo-200"></div>

      <div class="flex items-center gap-2">
        <span class="text-xs text-indigo-600 font-medium whitespace-nowrap">Set category:</span>
        <select
          data-kudos-dashboard-target="bulkCategoryInput"
          class="px-2 py-1 text-xs border border-indigo-300 rounded focus:outline-none focus:ring-1 focus:ring-indigo-500 bg-white">
          <option value="">Pick category…</option>
          <% @categories.each do |cat| %>
            <option value="<%= cat.name %>" title="<%= cat.description %>"><%= cat.name %></option>
          <% end %>
        </select>
        <button
          data-action="click->kudos-dashboard#bulkSetCategory"
          class="px-2.5 py-1 text-xs font-medium text-indigo-700 bg-white border border-indigo-300 rounded hover:bg-indigo-50 transition-colors">
          Apply
        </button>
      </div>

      <div class="h-4 w-px bg-indigo-200"></div>

      <div class="flex items-center gap-2">
        <button
          data-action="click->kudos-dashboard#bulkApprove"
          class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium rounded-md bg-green-50 text-green-700 border border-green-200 hover:bg-green-100 transition-colors">
          ✓ Approve all
        </button>
        <button
          data-action="click->kudos-dashboard#bulkReject"
          class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium rounded-md bg-red-50 text-red-700 border border-red-200 hover:bg-red-100 transition-colors">
          ✗ Reject all
        </button>
      </div>

      <button
        data-action="click->kudos-dashboard#clearSelection"
        class="ml-auto text-xs text-indigo-500 hover:text-indigo-700 transition-colors">
        Clear
      </button>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 w-8">
              <input
                type="checkbox"
                data-kudos-dashboard-target="selectAll"
                data-action="change->kudos-dashboard#toggleAll"
                class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer">
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Giver</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Receiver</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-2/5">Reason</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Reactions</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody data-kudos-dashboard-target="tbody" class="bg-white divide-y divide-gray-100">
          <% @kudos.each do |kudos| %>
            <tr
              data-kudos-dashboard-target="row"
              data-status="<%= kudos[:status] %>"
              data-id="<%= kudos[:id] %>"
              class="hover:bg-gray-50 transition-colors">
              <td class="px-4 py-3">
                <input
                  type="checkbox"
                  data-kudos-dashboard-target="checkbox"
                  data-action="change->kudos-dashboard#toggleRow"
                  class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer">
              </td>
              <td class="px-4 py-3 text-sm font-medium text-gray-900 whitespace-nowrap"><%= kudos[:giver] %></td>
              <td class="px-4 py-3 text-sm text-gray-700 whitespace-nowrap"><%= kudos[:receiver] %></td>
              <td class="px-4 py-3 text-sm whitespace-nowrap">
                <div class="flex items-center gap-1 group">
                  <span class="category-display inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-50 text-indigo-700">
                    <%= kudos[:category] %>
                  </span>
                  <button
                    class="opacity-0 group-hover:opacity-100 transition-opacity text-gray-400 hover:text-indigo-600"
                    data-action="click->kudos-dashboard#editCategory"
                    title="Edit category">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
                      <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/>
                    </svg>
                  </button>
                  <select
                    class="category-select hidden w-44 px-2 py-0.5 text-xs border border-indigo-300 rounded focus:outline-none focus:ring-1 focus:ring-indigo-500 bg-white"
                    data-action="change->kudos-dashboard#saveCategory blur->kudos-dashboard#saveCategory">
                    <% @categories.each do |cat| %>
                      <option value="<%= cat.name %>" title="<%= cat.description %>" <%= "selected" if cat.name == kudos[:category] %>><%= cat.name %></option>
                    <% end %>
                  </select>
                </div>
              </td>
              <td class="px-4 py-3 text-sm text-gray-600">
                <span class="line-clamp-2" title="<%= kudos[:reason] %>"><%= kudos[:reason] %></span>
              </td>
              <td class="px-4 py-3 text-sm text-gray-500 whitespace-nowrap">
                <span class="font-medium text-gray-700"><%= kudos[:reactions_count] %></span>
              </td>
              <td class="px-4 py-3 text-sm text-gray-500 whitespace-nowrap"><%= kudos[:date] %></td>
              <td class="px-4 py-3 whitespace-nowrap">
                <div class="flex items-center gap-2">
                  <button
                    data-action="click->kudos-dashboard#approve"
                    title="Approve"
                    class="approve-btn inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium rounded-md transition-colors">
                    ✓ Approve
                  </button>
                  <button
                    data-action="click->kudos-dashboard#reject"
                    title="Reject"
                    class="reject-btn inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium rounded-md transition-colors">
                    ✗ Reject
                  </button>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <!-- Empty state -->
      <div data-kudos-dashboard-target="emptyState" class="hidden py-16 text-center">
        <p class="text-sm text-gray-400">No kudos to show here.</p>
      </div>
    </div>

  </main>
</div>
